MONGODB_URL=mongodb://
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=memento
OLLAMA_URL=http://localhost:11434
LOG_LEVEL=INFO
JWT_SECRET_KEY=<your-secret-key>

# Provider AI
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Modelli Ollama
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Modelli OpenAI (usati solo se LLM_PROVIDER=openai)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Modelli Groq (usati solo se LLM_PROVIDER=groq)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# API Keys (lascia vuote se non usi il provider)
OPENAI_API_KEY=
GROQ_API_KEY=